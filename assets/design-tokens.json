{
  "$meta": {
    "name": "Spotify-inspired Design System",
    "source": "https://open.spotify.com/",
    "extractedAt": "2026-06-17",
    "note": "Dark-first design system mimicking the Spotify Web Player. Colors map to Spotify's Encore CSS custom properties."
  },
  "colors": {
    "brand": {
      "primary": "#1ED760",
      "primaryHover": "#3BE477",
      "primaryPress": "#1AB955",
      "classic": "#1DB954",
      "accent": "#1ED760",
      "error": "#F15E6C",
      "success": "#1ED760",
      "warning": "#FFA42B"
    },
    "background": {
      "base": "#121212",
      "highlight": "#1F1F1F",
      "elevatedBase": "#1F1F1F",
      "elevatedHighlight": "#2A2A2A",
      "press": "#000000",
      "tintedBase": "rgba(255, 255, 255, 0.07)",
      "tintedHighlight": "rgba(255, 255, 255, 0.10)",
      "overlay": "rgba(0, 0, 0, 0.7)"
    },
    "text": {
      "base": "#FFFFFF",
      "primary": "#FFFFFF",
      "secondary": "#B3B3B3",
      "subdued": "#B3B3B3",
      "muted": "#6A6A6A",
      "brightAccent": "#1ED760",
      "onAccent": "#000000"
    },
    "essential": {
      "base": "#FFFFFF",
      "subdued": "#B3B3B3",
      "brightAccent": "#1ED760",
      "negative": "#F15E6C"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "\"SpotifyMixUI\", \"Circular\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
      "title": "\"SpotifyMixUITitle\", \"Circular\", \"Helvetica Neue\", Helvetica, Arial, sans-serif"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "base": "14px",
      "md": "16px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "48px",
      "4xl": "72px",
      "5xl": "96px"
    },
    "lineHeight": {
      "tight": "1.2",
      "base": "1.4",
      "relaxed": "1.6"
    },
    "letterSpacing": {
      "normal": "0",
      "tight": "-0.04em"
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "borderRadius": {
    "none": "0px",
    "xs": "2px",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "16px",
    "full": "9999px",
    "pill": "500px",
    "circle": "50%"
  },
  "shadow": {
    "card": "0 8px 24px rgba(0, 0, 0, 0.5)",
    "elevated": "0 16px 24px rgba(0, 0, 0, 0.3)"
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#1ED760",
        "color": "#000000",
        "fontWeight": 700,
        "fontSize": "14px",
        "padding": "12px 32px",
        "minHeight": "48px",
        "borderRadius": "9999px",
        "border": "none",
        "hoverScale": "1.04",
        "hoverBackgroundColor": "#3BE477"
      },
      "secondary": {
        "backgroundColor": "transparent",
        "color": "#FFFFFF",
        "fontWeight": 700,
        "fontSize": "14px",
        "padding": "12px 32px",
        "minHeight": "48px",
        "borderRadius": "9999px",
        "border": "1px solid rgba(255, 255, 255, 0.3)",
        "hoverBorder": "1px solid #FFFFFF"
      },
      "chip": {
        "backgroundColor": "#1F1F1F",
        "color": "#FFFFFF",
        "fontSize": "14px",
        "fontWeight": 400,
        "padding": "8px 12px",
        "height": "32px",
        "borderRadius": "9999px",
        "hoverBackgroundColor": "#2A2A2A"
      },
      "iconCircle": {
        "backgroundColor": "#1F1F1F",
        "color": "#FFFFFF",
        "size": "48px",
        "borderRadius": "50%",
        "hoverBackgroundColor": "#2A2A2A"
      },
      "play": {
        "backgroundColor": "#1ED760",
        "color": "#000000",
        "size": "48px",
        "borderRadius": "50%",
        "hoverScale": "1.06",
        "hoverBackgroundColor": "#3BE477"
      }
    },
    "input": {
      "search": {
        "backgroundColor": "#1F1F1F",
        "color": "#FFFFFF",
        "placeholderColor": "#B3B3B3",
        "fontSize": "14px",
        "height": "48px",
        "padding": "12px 48px",
        "borderRadius": "9999px",
        "border": "1px solid transparent",
        "focusBorder": "1px solid #FFFFFF"
      }
    },
    "card": {
      "backgroundColor": "#181818",
      "hoverBackgroundColor": "#282828",
      "color": "#FFFFFF",
      "padding": "16px",
      "borderRadius": "8px",
      "transition": "background-color 0.3s ease"
    },
    "topbar": {
      "backgroundColor": "rgba(0, 0, 0, 0.5)",
      "color": "#FFFFFF",
      "padding": "16px",
      "height": "64px"
    },
    "sidebar": {
      "backgroundColor": "#000000",
      "color": "#B3B3B3",
      "activeColor": "#FFFFFF",
      "borderRadius": "8px",
      "itemPadding": "8px 12px"
    },
    "nowPlayingBar": {
      "backgroundColor": "#000000",
      "color": "#B3B3B3",
      "height": "86px",
      "progressTrack": "rgba(255, 255, 255, 0.3)",
      "progressFill": "#FFFFFF",
      "progressFillActive": "#1ED760"
    }
  }
}
